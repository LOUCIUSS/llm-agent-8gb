# ============================================================
# 8GB LLM Agent — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# --- Virtual Environment ---
.venv/
venv/
env/
ENV/

# --- Models (large binaries, download separately) ---
models/*.gguf
models/*.bin
models/*.safetensors
models/*.pt
models/*.pth
models/*.onnx
models/*.mlmodel
models/hub/
models/cache/

# --- Data & Logs ---
data/
logs/
*.log
uploads/
qdrant_data/
*.db
*.sqlite
*.sqlite3

# --- Environment ---
.env
.env.local
.env.*.local

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Testing ---
.coverage
.pytest_cache/
.tox/
htmlcov/

# --- Misc ---
*.bak
*.tmp
.session_*.md
